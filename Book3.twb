      <aliases enabled='yes' />
      <column caption='Postal Code Clean' datatype='string' name='[Calculation_1578925078118401]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF(ISNULL([Postal Code]),&quot;Not Applicable&quot;,STR([Postal Code]))' />
      </column>
      <column caption='Outlier Flag' datatype='string' name='[Calculation_1578925080072194]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ABS([Profit]) &gt; 5000 THEN&#13;&#10;&quot;Outlier&quot;&#13;&#10;ELSE&#13;&#10;&quot;Normal&quot;&#13;&#10;END' />
      </column>
